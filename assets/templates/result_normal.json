{
  "type": "bubble",
  "size": "mega",
  "header": {
    "type": "box",
    "layout": "vertical",
    "paddingAll": "16px",
    "backgroundColor": "#F9F9F9",
    "contents": [
      {
        "type": "text",
        "text": "AI 檢測分析報告",
        "weight": "bold",
        "size": "md",
        "color": "#333333"
      },
      {
        "type": "text",
        "text": "報告編號：PLACEHOLDER_REPORT_ID",
        "size": "xxs",
        "color": "#AAAAAA",
        "margin": "4px"
      }
    ]
  },
  "body": {
    "type": "box",
    "layout": "vertical",
    "paddingAll": "0px",
    "contents": [
      {
        "type": "box",
        "layout": "vertical",
        "paddingAll": "2px",
        "contents": [
          {
            "type": "box",
            "layout": "horizontal",
            "spacing": "xs",
            "contents": [
              {
                "type": "image",
                "url": "PLACEHOLDER_IMG_ORIGINAL_BOXED",
                "size": "full",
                "aspectRatio": "4:3",
                "aspectMode": "cover",
                "flex": 1,
                "action": { "type": "uri", "uri": "PLACEHOLDER_IMG_ORIGINAL_BOXED" }
              },
              {
                "type": "image",
                "url": "PLACEHOLDER_IMG_CROP",
                "size": "full",
                "aspectRatio": "4:3",
                "aspectMode": "cover",
                "flex": 1,
                "action": { "type": "uri", "uri": "PLACEHOLDER_IMG_CROP" }
              }
            ]
          }
        ]
      },
      {
        "type": "box",
        "layout": "vertical",
        "paddingAll": "20px",
        "contents": [
          {
            "type": "box",
            "layout": "horizontal",
            "contents": [
              {
                "type": "text",
                "text": "分析結果",
                "size": "sm",
                "color": "#888888",
                "flex": 1,
                "gravity": "center"
              },
              {
                "type": "box",
                "layout": "vertical",
                "backgroundColor": "#E8F5E9",
                "cornerRadius": "4px",
                "paddingStart": "8px",
                "paddingEnd": "8px",
                "paddingTop": "4px",
                "paddingBottom": "4px",
                "flex": 0,
                "contents": [
                  {
                    "type": "text",
                    "text": "正常 / 低風險",
                    "color": "#2E7D32",
                    "size": "sm",
                    "weight": "bold"
                  }
                ]
              }
            ]
          },
          { "type": "separator", "margin": "16px" },
          {
            "type": "text",
            "text": "影像特徵未見明顯異常。建議持續保持良好用眼習慣，並定期進行視力檢查。",
            "margin": "16px",
            "size": "sm",
            "color": "#555555",
            "wrap": true,
            "lineSpacing": "4px"
          }
        ]
      }
    ]
  },
  "footer": {
    "type": "box",
    "layout": "vertical",
    "paddingAll": "16px",
    "contents": [
      {
        "type": "button",
        "action": { 
          "type": "postback", 
          "label": "👀 護眼小知識", 
          "data": "action=view_education&topic=prevention"
        },
        "style": "secondary",
        "color": "#17A2B8",
        "height": "sm"
      },
      {
        "type": "button",
        "action": { "type": "postback", "label": "重新檢測", "data": "action=retry" },
        "margin": "12px",
        "height": "sm",
        "style": "link",
        "color": "#2E7D32"
      }
    ]
  }
}